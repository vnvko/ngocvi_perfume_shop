# Server
PORT=5000
NODE_ENV=development

# Database - thay bằng thông tin MySQL của bạn
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=ngocvi_perfume_shop

# JWT - đổi secret key trong production
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Frontend URL
FRONTEND_URL=http://localhost:5173
